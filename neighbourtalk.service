[Unit]
Description=NeighbourTalk EN<->RO Translation App
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/neighbourtalk
EnvironmentFile=/home/pi/neighbourtalk/.env
ExecStart=/home/pi/neighbourtalk/venv/bin/uvicorn main:app --host 0.0.0.0 --port 5000 --workers 2
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
