# Copy this file to .env and fill in your keys.
# Then: chmod 600 .env

# OpenAI API key — used for Whisper (STT) and TTS
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# DeepL API key (free tier is sufficient)
# https://www.deepl.com/en/pro-api  — use the Authentication Key shown in your account
DEEPL_API_KEY=...
